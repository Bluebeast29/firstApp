<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.FirstApp" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/white</item>
        <item name="android:windowBackground">@drawable/app_bg_gradient</item>
        <item name="android:statusBarColor">#6A11CB</item>
    </style>

    <style name="Theme.FirstApp" parent="Base.Theme.FirstApp">
    </style>

    <!-- Production-Level Glass Styles -->
    <style name="AppTextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/white</item>
        <item name="boxBackgroundColor">@color/glass_input_bg</item>
        <item name="hintTextColor">@color/white</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="errorTextColor">@color/error_red</item>
        <item name="boxStrokeErrorColor">@color/error_red</item>
    </style>

    <style name="AppButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/white</item>
        <item name="android:textColor">@color/on_glass_primary</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Material3.Corner.Large</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

</resources>